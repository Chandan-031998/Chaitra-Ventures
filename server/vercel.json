{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": ["index.js", "schema.sql", "uploads/**"]
    }
  },
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ]
}
